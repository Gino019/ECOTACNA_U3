# ============================================================
# ECO_TACNA BACKEND - Variables locales/de despliegue
# Copiar manualmente a '.env' o cargar en el entorno de despliegue.
# No pegar valores reales en este archivo versionado.
# ============================================================

SPRING_PROFILES_ACTIVE=supabase

SERVER_PORT=8082

# Base de datos
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_MAX_POOL_SIZE=3

# Seguridad y Autenticacion
JWT_SECRET=
JWT_EXPIRATION=86400000

# Bootstrap (Creacion de superadmin)
ECOTACNA_BOOTSTRAP_ENABLED=false
ECOTACNA_BOOTSTRAP_ADMIN_EMAIL=
ECOTACNA_BOOTSTRAP_ADMIN_PASSWORD=

# Funcionalidades adicionales
CAPTCHA_ENABLED=true
PAYMENTS_ENABLED=true
PAYMENTS_MODE=simulated

# Integraciones de API externas
RUC_PROVIDER=apiperudev
APIPERUDEV_API_TOKEN=
APIPERUDEV_API_BASE_URL=https://apiperu.dev/api

# Google Maps API para Backend (si se usa en el futuro)
GOOGLE_MAPS_API_KEY=

AI_RECOMMENDATION_MODE=INTERNAL
AI_RECOMMENDATION_SERVICE_URL=http://localhost:8091
AI_RECOMMENDATION_SERVICE_TOKEN=
